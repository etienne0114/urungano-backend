# Server Configuration
PORT=4000
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGIN=*

# Database Configuration (PostgreSQL / Supabase)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=urungano
# Connection string (preferred for production/Supabase)
DATABASE_URL=postgres://user:pass@host:port/dbname

# Security
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_EXPIRATION=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# TTS & Narration
TTS_ENGINE=google
SYNTHESIZE_SCRIPT_PATH=scripts/synthesize.py
